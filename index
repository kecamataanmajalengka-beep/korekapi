                '<p class="font-bold text-light text-sm">Sumatif Akhir Tahun</p>' +
                '<p class="text-xs text-muted mt-0.5">SAT &middot; '+g.kelas+'</p>' +
                '<p class="text-xs text-muted mt-1">'+doneCount+'/'+satMapels.length+' mapel selesai</p>' +
                (allDone?'<div class="mt-1"><span class="badge badge-success text-xs"><i class="fas fa-check mr-1"></i>Selesai</span></div>':'') +
            '</div>';
