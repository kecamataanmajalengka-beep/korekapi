            '<p class="text-xs text-muted mt-1">'+satDoneCount+'/'+satMapels.length+' mapel selesai</p>' +
            (satAllDone?'<div class="mt-1"><span class="badge badge-success text-xs"><i class="fas fa-check mr-1"></i>Semua Selesai</span></div>':'') +
