function getSatMapelsForGuru(guru){
    var tm=guru.tokenMapel||{};
    var mapels=[];
    Object.keys(tm).forEach(function(m){var mel=MAPEL_LIST.find(function(x){return x.id===m;});if(mel)mapels.push(mel);});
    return mapels;
}

function selectExamType(type){
    selectedExamType=type;selectedMapel=null;tokenValidated=false;
    var area=document.getElementById('mapelSelectArea');

    if(type==='paj'){
        // PAJ: langsung tentukan guru dan mapel
        selectedGuru=matchedNpsnGurus.find(function(g){return g.kelas==='Kelas 6';});
        selectedMapel='paj';
        // Highlight card
        document.querySelectorAll('.exam-type-card').forEach(function(c){c.classList.remove('selected');});
        document.getElementById('cardPAJ').classList.add('selected');
        area.classList.add('hidden');
        document.getElementById('btnStep3').disabled=false;
        document.getElementById('lMapelErr').classList.add('hidden');
        return;
    }

    // SAT: perlu pilih mapel dulu
    var kelas;
    if(type==='sat6')kelas='Kelas 6';
    else kelas=type.replace('sat_','Kelas ');

    selectedGuru=matchedNpsnGurus.find(function(g){return g.kelas===kelas;});
    if(!selectedGuru)selectedGuru=matchedNpsnGurus[0];

    var satMapels=getSatMapelsForGuru(selectedGuru);
    if(!satMapels.length){showToast('Tidak ada mapel SAT untuk kelas ini','error');return;}

    // Highlight card
    document.querySelectorAll('.exam-type-card').forEach(function(c){c.classList.remove('selected');});
    var cardId=type==='sat6'?'cardSAT6':'cardSAT_'+kelas.replace(' ','');
    var card=document.getElementById(cardId);if(card)card.classList.add('selected');

    // Tampilkan grid mapel
    var h='<div class="mt-3 pt-3 border-t border-border"><p class="text-xs text-muted mb-2 font-semibold">Pilih Mata Pelajaran:</p><div class="grid grid-cols-2 gap-2">';
    satMapels.forEach(function(m){
        var done=alreadyDoneSet[m.id];
        h+='<div class="mapel-card'+(done?' locked':'')+'" onclick="selectSatMapel(\''+m.id+'\')">' +
            '<div class="w-8 h-8 rounded-lg bg-kopAccent/15 flex items-center justify-center flex-shrink-0"><i class="fas '+m.icon+' text-kopAccent text-xs"></i></div>' +
            '<div class="min-w-0 flex-1"><p class="text-xs font-semibold text-light truncate">'+escHtml(m.singkat)+'</p>' +
            (done?'<span class="badge badge-success" style="font-size:9px;padding:1px 6px"><i class="fas fa-check"></i></span>':'<p class="text-xs text-muted" style="font-size:10px">'+escHtml(m.nama)+'</p>') +
            '</div></div>';
    });
    h+='</div></div>';
    area.innerHTML=h;
    area.classList.remove('hidden');
    document.getElementById('btnStep3').disabled=true;
}

function selectSatMapel(m){
