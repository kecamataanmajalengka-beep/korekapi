<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;-webkit-text-size-adjust:100%}
html,body{width:100%;overflow-x:hidden}
body{font-family:'Source Sans 3',sans-serif;background:#0f1923;color:#e8ecf1;min-height:100vh;min-height:100dvh;padding-bottom:env(safe-area-inset-bottom)}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:#182538}::-webkit-scrollbar-thumb{background:#2a3f5f;border-radius:2px}

/* Auth */
.auth-bg{background:linear-gradient(160deg,#080d14 0%,#0f1923 30%,#1a2744 70%,#0f1923 100%);min-height:100vh;min-height:100dvh;display:flex;align-items:center;justify-content:center;padding:16px;position:relative;overflow:hidden}
.auth-bg::before{content:'';position:absolute;width:320px;height:320px;background:radial-gradient(circle,rgba(6,182,212,0.06) 0%,transparent 70%);top:-80px;left:-60px;border-radius:50%;animation:blobA 10s ease-in-out infinite}
.auth-bg::after{content:'';position:absolute;width:260px;height:260px;background:radial-gradient(circle,rgba(201,168,76,0.05) 0%,transparent 70%);bottom:-60px;right:-40px;border-radius:50%;animation:blobA 12s ease-in-out infinite reverse}
@keyframes blobA{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(15px,-10px) scale(1.06)}}
.glass{background:rgba(24,37,56,0.9);backdrop-filter:blur(20px);border:1px solid rgba(42,63,95,0.5)}

/* Step dots */
.step-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;transition:all .3s;flex-shrink:0}
.step-dot.inactive{background:#2a3f5f;color:#7a8ba5}
.step-dot.active{background:linear-gradient(135deg,#c9a84c,#b8943f);color:#1a2744;box-shadow:0 0 16px rgba(201,168,76,0.3)}
.step-dot.done{background:#22c55e;color:white}
.step-dot.error{background:#ef4444;color:white;animation:shake .4s ease}
.step-line{height:2px;flex:1;background:#2a3f5f;transition:background .3s;min-width:12px}
.step-line.done{background:#22c55e}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-5px)}75%{transform:translateX(5px)}}

/* Token */
.token-wrap{position:relative}
.token-wrap input{letter-spacing:8px;font-size:22px;font-weight:700;text-align:center;font-family:'Courier New',monospace;padding:14px 12px;text-transform:uppercase}
.token-mask{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;color:#2a3f5f;font-size:22px;font-weight:700;letter-spacing:8px;font-family:'Courier New',monospace}

/* Mapel cards */
.mapel-card{padding:14px;border-radius:12px;cursor:pointer;transition:all .15s;border:1.5px solid #2a3f5f;background:#0f1923;display:flex;align-items:center;gap:12px;-webkit-user-select:none;user-select:none}
.mapel-card:active{transform:scale(0.98)}
.mapel-card.selected{border-color:#c9a84c;background:rgba(201,168,76,0.1);box-shadow:0 0 12px rgba(201,168,76,0.12)}
.mapel-card.locked{opacity:.35;pointer-events:none}

/* Buttons */
.btn-primary{background:linear-gradient(135deg,#c9a84c,#b8943f);color:#1a2744;font-weight:700;padding:13px 24px;border-radius:10px;border:none;cursor:pointer;transition:all .15s;font-size:15px;font-family:'Source Sans 3',sans-serif;display:inline-flex;align-items:center;justify-content:center;width:100%;-webkit-user-select:none;user-select:none}
.btn-primary:active{transform:scale(0.98);opacity:.9}
.btn-primary:disabled{opacity:.35;pointer-events:none}
.btn-secondary{background:transparent;border:1.5px solid #2a3f5f;color:#e8ecf1;padding:11px 24px;border-radius:10px;cursor:pointer;transition:all .15s;font-size:14px;font-family:'Source Sans 3',sans-serif;display:inline-flex;align-items:center;justify-content:center;width:100%}
.btn-secondary:active{background:rgba(42,63,95,0.3)}
.input-field{background:#0f1923;border:1.5px solid #2a3f5f;color:#e8ecf1;padding:13px 14px;border-radius:10px;width:100%;font-size:16px;transition:border-color .2s;font-family:'Source Sans 3',sans-serif}
.input-field:focus{outline:none;border-color:#c9a84c;box-shadow:0 0 0 2px rgba(201,168,76,0.12)}
.input-field::placeholder{color:#5a6b82}

/* Main */
.main-wrap{background:#0f1923;min-height:100vh;min-height:100dvh}
.topbar{background:rgba(15,25,35,0.95);backdrop-filter:blur(12px);border-bottom:1px solid #2a3f5f;position:sticky;top:0;z-index:50;padding:12px 16px}

/* Ujian */
.radio-opt{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;border-radius:10px;cursor:pointer;transition:all .12s;border:1.5px solid transparent;-webkit-user-select:none;user-select:none}
.radio-opt:active{transform:scale(0.99)}
.radio-opt.selected{background:rgba(201,168,76,0.08);border-color:rgba(201,168,76,0.35)}
.radio-opt input[type="radio"]{accent-color:#c9a84c;width:18px;height:18px;flex-shrink:0;margin-top:1px}
.progress-bar{height:4px;background:#2a3f5f;border-radius:2px;overflow:hidden;position:sticky;top:52px;z-index:40}
.progress-fill{height:100%;background:linear-gradient(90deg,#c9a84c,#22c55e);border-radius:2px;transition:width .3s}

/* Exam type selector */
.exam-type-card{padding:20px 16px;border-radius:14px;cursor:pointer;transition:all .15s;border:2px solid #2a3f5f;background:#0f1923;text-align:center;-webkit-user-select:none;user-select:none}
.exam-type-card:active{transform:scale(0.97)}
.exam-type-card.selected{border-color:#c9a84c;background:rgba(201,168,76,0.08)}

/* Toast */
.toast{position:fixed;top:12px;left:12px;right:12px;z-index:9999;padding:12px 16px;border-radius:10px;font-size:13px;font-weight:600;animation:toastIn .3s ease;display:flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(0,0,0,0.4);max-width:100%}
.toast-success{background:linear-gradient(135deg,#166534,#15803d);color:white;border:1px solid #22c55e}
.toast-error{background:linear-gradient(135deg,#7f1d1d,#991b1b);color:white;border:1px solid #ef4444}
.toast-info{background:linear-gradient(135deg,#164e63,#155e75);color:white;border:1px solid #06b6d4}
@keyframes toastIn{from{transform:translateY(-30px);opacity:0}to{transform:translateY(0);opacity:1}}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.fade-in{animation:fadeIn .25s ease forwards}
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.badge-success{background:rgba(34,197,94,0.15);color:#22c55e}
.badge-danger{background:rgba(239,68,68,0.15);color:#ef4444}
.badge-info{background:rgba(6,182,212,0.15);color:#06b6d4}
.badge-warning{background:rgba(245,158,11,0.15);color:#f59e0b}

/* Siswa dropdown */
.siswa-drop{max-height:180px;overflow-y:auto;background:#0f1923;border:1.5px solid #2a3f5f;border-radius:10px}
.siswa-drop-item{padding:10px 14px;border-bottom:1px solid rgba(42,63,95,0.3);cursor:pointer;transition:background .1s}
.siswa-drop-item:active{background:rgba(42,63,95,0.4)}
.siswa-drop-item:last-child{border-bottom:none}

/* Result */
.result-score{font-family:'Playfair Display',serif;font-size:72px;font-weight:900;line-height:1}
@keyframes countUp{from{opacity:0;transform:scale(0.5)}to{opacity:1;transform:scale(1)}}
.score-anim{animation:countUp .5s ease forwards}
</style>
</head>
<body>
<div id="toastContainer"></div>

<!-- ==================== LOGIN 4 STEP ==================== -->
<div id="loginPage" class="auth-bg">
<div class="glass rounded-2xl p-6 w-full max-w-sm relative z-10 fade-in" style="max-height:96vh;overflow-y:auto">
    <div class="text-center mb-5">
        <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-info/15 flex items-center justify-center border-2 border-info/30">
            <i class="fas fa-user-graduate text-info text-2xl"></i>
        </div>
        <h1 class="font-display text-xl font-bold text-info">PANEL SISWA</h1>
        <p class="text-muted text-xs mt-1">KOREK API Kec. Majalengka</p>
    </div>

    <div class="flex items-center justify-center gap-1.5 mb-4 px-2">
        <div class="step-dot active" id="sd1">1</div><div class="step-line" id="sl1"></div>
        <div class="step-dot inactive" id="sd2">2</div><div class="step-line" id="sl2"></div>
        <div class="step-dot inactive" id="sd3">3</div><div class="step-line" id="sl3"></div>
        <div class="step-dot inactive" id="sd4">4</div>
    </div>
    <div class="flex justify-between mb-4 px-1 text-xs text-muted">
        <span id="slbl1" class="text-center w-14">NPSN</span>
        <span id="slbl2" class="text-center w-14">Jenis</span>
        <span id="slbl3" class="text-center w-14">Token</span>
        <span id="slbl4" class="text-center w-14">Nama</span>
    </div>

    <!-- STEP 1 -->
    <div id="step1">
        <div class="text-center mb-2"><p class="text-xs text-kopAccent font-bold uppercase tracking-wider">Langkah 1</p><p class="text-xs text-muted">Masukkan NPSN sekolah</p></div>
        <div class="relative mb-2"><i class="fas fa-school absolute left-4 top-1/2 -translate-y-1/2 text-muted text-sm"></i><input type="text" id="lNpsn" class="input-field pl-11" placeholder="Ketik NPSN..." inputmode="numeric" oninput="onNpsnInput()" onkeydown="if(event.key==='Enter')doStep2()"></div>
        <div id="lSekolahInfo" class="hidden mb-2 p-3 rounded-lg border text-sm"></div>
        <p id="lNpsnErr" class="text-danger text-xs hidden mb-2"></p>
        <button onclick="doStep2()" id="btnStep2" class="btn-primary" disabled>Lanjutkan <i class="fas fa-arrow-right ml-2"></i></button>
    </div>

    <!-- STEP 2 -->
    <div id="step2" class="hidden">
        <div class="text-center mb-2"><p class="text-xs text-kopAccent font-bold uppercase tracking-wider">Langkah 2</p><p class="text-xs text-muted">Pilih jenis ujian</p></div>
        <div id="lGuruInfo" class="mb-3 p-3 bg-dark/40 rounded-lg border border-border text-xs space-y-1"></div>
        <div id="lExamTypeArea" class="space-y-3 mb-3"></div>
        <p id="lMapelErr" class="text-danger text-xs hidden mb-2"></p>
        <button onclick="doStep3()" id="btnStep3" class="btn-primary" disabled>Lanjutkan <i class="fas fa-arrow-right ml-2"></i></button>
        <button onclick="backToStep(1)" class="btn-secondary mt-2 text-xs py-2.5"><i class="fas fa-arrow-left mr-1"></i>Kembali</button>
    </div>

    <!-- STEP 3 -->
    <div id="step3" class="hidden">
        <div class="text-center mb-2"><p class="text-xs text-kopAccent font-bold uppercase tracking-wider">Langkah 3</p><p class="text-xs text-muted">Masukkan token dari guru</p></div>
        <div id="lTokenInfo" class="mb-3 p-3 bg-dark/40 rounded-lg border border-border text-xs space-y-1"></div>
        <div class="mb-2"><label class="text-xs text-muted mb-1.5 block text-center">Token untuk <strong id="lTokenLabel" class="text-kopAccent"></strong></label>
            <div class="token-wrap"><input type="text" id="lToken" class="input-field" placeholder="XXXXXXXX" maxlength="8" oninput="onTokenInput()" onkeydown="if(event.key==='Enter')doStep4()"><span class="token-mask" id="tokenMask">········</span></div>
        </div>
        <p id="lTokenErr" class="text-danger text-xs hidden mb-2 text-center"></p>
        <div id="lTokenOk" class="hidden mb-2 p-3 bg-success/10 border border-success/30 rounded-lg text-success text-xs text-center"><i class="fas fa-check-circle mr-1"></i>Token valid!</div>
        <button onclick="doStep4()" id="btnStep4" class="btn-primary" disabled>Lanjutkan <i class="fas fa-arrow-right ml-2"></i></button>
        <button onclick="backToStep(2)" class="btn-secondary mt-2 text-xs py-2.5"><i class="fas fa-arrow-left mr-1"></i>Kembali</button>
    </div>

    <!-- STEP 4 -->
    <div id="step4" class="hidden">
        <div class="text-center mb-2"><p class="text-xs text-kopAccent font-bold uppercase tracking-wider">Langkah 4</p><p class="text-xs text-muted">Masukkan identitas</p></div>
        <div id="lSummaryInfo" class="mb-3 p-3 bg-dark/40 rounded-lg border border-border text-xs space-y-1"></div>
        <div class="relative mb-2"><i class="fas fa-user absolute left-4 top-1/2 -translate-y-1/2 text-muted text-sm"></i><input type="text" id="lNama" class="input-field pl-11 pr-10" placeholder="Nama lengkap..." onkeydown="if(event.key==='Enter')doFinalLogin()" oninput="document.getElementById('btnLogin').disabled=!this.value.trim()"><button onclick="showSiswaList()" class="absolute right-3 top-1/2 -translate-y-1/2 text-kopAccent p-1" type="button"><i class="fas fa-list text-sm"></i></button></div>
        <div id="lSiswaDrop" class="hidden siswa-drop mb-2"></div>
        <p id="lNamaErr" class="text-danger text-xs hidden mb-2"></p>
        <button onclick="doFinalLogin()" id="btnLogin" class="btn-primary" disabled><i class="fas fa-sign-in-alt mr-2"></i>Mulai Ujian</button>
        <button onclick="backToStep(3)" class="btn-secondary mt-2 text-xs py-2.5"><i class="fas fa-arrow-left mr-1"></i>Kembali</button>
    </div>
</div>
</div>

<!-- ==================== MAIN UJIAN ==================== -->
<div id="mainPage" class="main-wrap hidden">
    <header class="topbar no-print">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-info to-cyan-600 flex items-center justify-center flex-shrink-0"><i class="fas fa-user-graduate text-white text-xs"></i></div>
                <div class="min-w-0"><p class="text-sm font-semibold text-light truncate" id="topNama" style="max-width:140px"></p><p class="text-xs text-muted truncate" id="topInfo" style="max-width:160px"></p></div>
            </div>
            <div class="flex items-center gap-2">
                <span class="badge badge-info text-xs" id="topMapel"></span>
                <button onclick="doLogout()" class="w-8 h-8 rounded-lg border border-border flex items-center justify-center text-muted hover:text-danger hover:border-danger transition-colors"><i class="fas fa-sign-out-alt text-xs"></i></button>
            </div>
        </div>
    </header>
    <div class="p-4" id="pageContent"></div>
</div>

<script>
var firebaseConfig={apiKey:"AIzaSyC0Hs7SUgPAeQ_JaotHUJL5m6nIhCRif-8",authDomain:"pembuatan-soal.firebaseapp.com",projectId:"pembuatan-soal",storageBucket:"pembuatan-soal.firebasestorage.app",messagingSenderId:"56200686194",appId:"1:56200686194:web:eb2de00c9d152d87bcf0eb"};
firebase.initializeApp(firebaseConfig);
var db=firebase.firestore();

var MAPEL_LIST=[
    {id:'ppkn',nama:'Pendidikan Pancasila',singkat:'PPKn',icon:'fa-balance-scale'},
    {id:'mat',nama:'Matematika',singkat:'Mat',icon:'fa-calculator'},
    {id:'bin',nama:'Bahasa Indonesia',singkat:'B.Indo',icon:'fa-book'},
    {id:'sbd',nama:'Seni Budaya',singkat:'Seni',icon:'fa-palette'},
    {id:'ipas',nama:'IPAS',singkat:'IPAS',icon:'fa-flask'},
    {id:'bsd',nama:'Bahasa Sunda',singkat:'B.Sunda',icon:'fa-language'},
    {id:'bing',nama:'Bahasa Inggris',singkat:'B.Inggris',icon:'fa-globe'},
    {id:'pai',nama:'PAI',singkat:'PAI',icon:'fa-mosque'},
    {id:'pjok',nama:'PJOK',singkat:'PJOK',icon:'fa-running'}
];

function getOptLetters(k){var n=parseInt((k||'').replace('Kelas ',''))||0;return n<=2?['a','b','c']:n===6?['a','b','c','d','e']:['a','b','c','d'];}
function getMapelName(id){if(id==='paj')return'Penilaian Akhir Jenjang';var m=MAPEL_LIST.find(function(x){return x.id===id;});return m?m.nama:id;}
function getMapelSingkat(id){if(id==='paj')return'PAJ';var m=MAPEL_LIST.find(function(x){return x.id===id;});return m?m.singkat:id;}
function getMapelIcon(id){if(id==='paj')return'fa-graduation-cap';var m=MAPEL_LIST.find(function(x){return x.id===id;});return m?m.icon:'fa-book';}
function escHtml(s){if(!s)return'';var d=document.createElement('div');d.textContent=String(s);return d.innerHTML;}

var guruList=[],siswaList=[],questions=[],pajQuestions=[];
var unsubG=null,unsubS=null,unsubQ=null,unsubPAJ=null;
var sessionData=null,loginStep=1;
var matchedNpsnGurus=[],selectedGuru=null,selectedMapel=null,selectedExamType=null,tokenValidated=false;
var alreadyDoneSet={},nilaiCache=[];

function showToast(msg,type){type=type||'success';var c=document.getElementById('toastContainer'),t=document.createElement('div'),ic=type==='success'?'check-circle':type==='error'?'times-circle':'info-circle';t.className='toast toast-'+type;t.innerHTML='<i class="fas fa-'+ic+' flex-shrink-0"></i><span>'+msg+'</span>';c.appendChild(t);setTimeout(function(){if(t.parentNode)t.remove();},3500);}

function updateStepUI(s){
    loginStep=s;
    for(var i=1;i<=4;i++){var dot=document.getElementById('sd'+i),lbl=document.getElementById('slbl'+i);dot.className='step-dot '+(i<s?'done':i===s?'active':'inactive');if(i<s){dot.innerHTML='<i class="fas fa-check" style="font-size:10px"></i>';lbl.style.color='#22c55e';}else if(i===s){dot.textContent=i;lbl.style.color='#c9a84c';}else{dot.textContent=i;lbl.style.color='#7a8ba5';}}
    for(var i=1;i<=3;i++)document.getElementById('sl'+i).className='step-line'+(i<s?' done':'');
    for(var i=1;i<=4;i++)document.getElementById('step'+i).classList.toggle('hidden',i!==s);
}

function initApp(){
    unsubG=db.collection('guru_panel').onSnapshot(function(s){guruList=s.docs.map(function(d){return Object.assign({id:d.id},d.data());});if(loginStep<=2)onNpsnInput();});
    unsubS=db.collection('siswa_panel').onSnapshot(function(s){siswaList=s.docs.map(function(d){return Object.assign({id:d.id},d.data());});});
    unsubQ=db.collection('questions').orderBy('createdAt','asc').onSnapshot(function(s){questions=s.docs.map(function(d){return Object.assign({id:d.id},d.data());});});
    unsubPAJ=db.collection('questions_paj').orderBy('createdAt','asc').onSnapshot(function(s){pajQuestions=s.docs.map(function(d){return Object.assign({id:d.id},d.data());});});
}

// ====== STEP 1: NPSN ======
function onNpsnInput(){
    var npsn=(document.getElementById('lNpsn').value||'').trim();
    var info=document.getElementById('lSekolahInfo'),err=document.getElementById('lNpsnErr'),btn=document.getElementById('btnStep2');
    err.classList.add('hidden');matchedNpsnGurus=[];selectedGuru=null;selectedMapel=null;selectedExamType=null;tokenValidated=false;
    if(!npsn){info.classList.add('hidden');btn.disabled=true;return;}
    matchedNpsnGurus=guruList.filter(function(g){return g.npsn===npsn;});
    if(!matchedNpsnGurus.length){info.classList.remove('hidden');info.className='mb-2 p-3 rounded-lg border text-sm border-danger/30 bg-danger/5 text-danger';info.innerHTML='<i class="fas fa-exclamation-triangle mr-1"></i>NPSN <strong>'+escHtml(npsn)+'</strong> tidak ditemukan';btn.disabled=true;}
    else{var sk=matchedNpsnGurus[0].sekolah;info.classList.remove('hidden');info.className='mb-2 p-3 rounded-lg border text-sm border-success/30 bg-success/5 text-success';info.innerHTML='<i class="fas fa-check-circle mr-1"></i><strong>'+escHtml(sk)+'</strong>';btn.disabled=false;}
}
function doStep2(){if(!matchedNpsnGurus.length){showToast('NPSN tidak valid','error');return;}updateStepUI(2);renderStep2();}
function backToStep(s){updateStepUI(s);if(s===1)document.getElementById('lNpsn').focus();if(s===2)renderStep2();if(s===3)renderStep3();}

// ====== STEP 2: JENIS UJIAN ======
function renderStep2(){
    var gi=document.getElementById('lGuruInfo'),area=document.getElementById('lExamTypeArea'),err=document.getElementById('lMapelErr'),btn=document.getElementById('btnStep3');
    err.classList.add('hidden');selectedMapel=null;selectedExamType=null;tokenValidated=false;btn.disabled=true;
    var g0=matchedNpsnGurus[0];
    gi.innerHTML='<div class="flex items-center gap-2"><i class="fas fa-school text-kopAccent" style="font-size:10px"></i><span class="text-light font-semibold">'+escHtml(g0.sekolah)+'</span></div><div class="flex items-center gap-2"><i class="fas fa-chalkboard-teacher text-info" style="font-size:10px"></i><span class="text-muted">'+matchedNpsnGurus.map(function(g){return escHtml(g.nama+' ('+g.kelas+')');}).join(', ')+'</span></div>';

    // Cek apakah ada guru Kelas 6
    var hasK6=matchedNpsnGurus.some(function(g){return g.kelas==='Kelas 6';});

    // Load cache nilai
    loadNilaiCache(matchedNpsnGurus[0].npsn);

    var h='';

    if(hasK6){
        // Tampilkan 2 pilihan: SAT dan PAJ
