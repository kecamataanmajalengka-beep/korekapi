function updateProgress(){
    var bar=document.getElementById('ujProgress');if(!bar)return;
    var total=document.querySelectorAll('#pgContainer > div').length;if(!total){bar.style.width='0%';return;}
    var ans=0;for(var i=0;i<total;i++){if(document.querySelector('input[name="uj_pg_'+i+'"]:checked'))ans++;}
    bar.style.width=Math.round(ans/total*100)+'%';
}
function selectOpt(qi,oi){
    document.querySelectorAll('[name="uj_pg_'+qi+'"]').forEach(function(r){r.closest('.radio-opt').classList.remove('selected');});
    var t=document.getElementById('ropt_'+qi+'_'+oi);if(t)t.classList.add('selected');updateProgress();
}

function submitUjian(){
    var g=sessionData.guru,m=sessionData.mapel,k=sessionData.kelas,isPaj=m==='paj';
    var source=isPaj?pajQuestions:questions;
    var allQ=source.filter(function(q){if(q.kelas!==k)return false;if(!isPaj)return q.mapel===m;return true;});
    var pgQ=allQ.filter(function(q){return q.type==='pg';}),urQ=allQ.filter(function(q){return q.type==='uraian';});
    var pgMax=0;pgQ.forEach(function(q){pgMax+=(q.score||0);});
    var urMax=0;urQ.forEach(function(q){urMax+=(q.score||0);});
    var pgSkor=0,pgDetail=[];
    var unanswered=[];
    pgQ.forEach(function(q,i){if(!document.querySelector('input[name="uj_pg_'+i+'"]:checked'))unanswered.push(i+1);});
    if(unanswered.length&&!confirm('Soal nomor '+unanswered.join(', ')+' belum dijawab. Lanjutkan?'))return;

    pgQ.forEach(function(q,i){
        var el=document.querySelector('input[name="uj_pg_'+i+'"]:checked');
        var jawaban=el?el.value.toUpperCase():'',kunci=(q.answer||'').toUpperCase(),benar=(jawaban===kunci);
        if(benar)pgSkor+=(q.score||1);
        pgDetail.push({no:i+1,kunci:kunci,jawaban:jawaban,benar:benar,soal:q.text});
    });

    var total=hitungNilai(pgSkor,0,pgMax,urMax);
    var benarCount=pgDetail.filter(function(d){return d.benar;}).length;

    var btn=document.getElementById('btnSubmit');if(btn){btn.disabled=true;btn.innerHTML='<span class="loading-spinner" style="border-color:rgba(26,39,68,0.3);border-top-color:#1a2744"></span> Mengirim...';}

    var data={
        guruId:g.id,npsn:g.npsn,sekolah:g.sekolah,kelas:k,rombel:g.rombel,
        mapel:m,nama:sessionData.nama,absen:1,
        pgSkor:pgSkor,urSkor:0,pgMax:pgMax,urMax:urMax,
        nilaiAkhir:total,pgDetail:pgDetail,
        createdAt:firebase.firestore.FieldValue.serverTimestamp(),
        source:'siswa_panel'
    };

    db.collection('nilai_panel').add(data).then(function(){
        showResult(total,pgSkor,pgMax,benarCount,pgQ.length,pgDetail);
        showToast('Nilai '+total+' terkirim!');
    }).catch(function(e){
        showToast('Gagal: '+(e.message||''),'error');
        if(btn){btn.disabled=false;btn.innerHTML='<i class="fas fa-paper-plane mr-2"></i>Selesai & Kirim Nilai';}
    });
}

function hitungNilai(pg,ur,pm,um){if(!pm&&!um)return 0;if(!pm)return Math.round(ur/um*100);if(!um)return Math.round(pg/pm*100);return Math.round((pg/pm*40)+(ur/um*60));}

function showResult(nilai,pgSkor,pgMax,benar,total,pgDetail){
    document.getElementById('soalArea').style.display='none';
    var noPrint=document.querySelectorAll('.no-print');noPrint.forEach(function(el){el.style.display='none';});
    var isLulus=nilai>=70,predikat=nilai>=90?'A':nilai>=80?'B':nilai>=70?'C':nilai>=60?'D':'E';
    var pct=pgMax>0?Math.round(pgSkor/pgMax*100):0;

    var h='<div class="fade-in text-center px-2">';
    // Big score
    h+='<div class="py-6">';
    h+='<div class="w-20 h-20 mx-auto mb-4 rounded-full '+(isLulus?'bg-success/15':'bg-danger/15')+' flex items-center justify-center"><i class="fas '+(isLulus?'fa-trophy text-success':'fa-redo text-danger')+' text-3xl"></i></div>';
    h+='<p class="text-xs text-muted mb-1">Nilai Akhir</p>';
    h+='<p class="result-score score-anim '+(isLulus?'text-success':'text-danger')+'">'+nilai+'</p>';
    h+='<p class="text-base font-bold '+(isLulus?'text-success':'text-danger')+' mt-1">Predikat '+predikat+'</p>';
    h+='<p class="text-xs '+(isLulus?'text-success/70':'text-danger/70')+' mt-1">'+(isLulus?'Selamat, kamu tuntas!':'Belum tuntas, tetap semangat!')+'</p>';
    h+='</div>';

    // Stats
    h+='<div class="grid grid-cols-3 gap-3 mb-5">';
    h+='<div class="bg-card rounded-xl border border-border p-3"><p class="text-xs text-muted mb-1">Benar</p><p class="text-xl font-bold text-success">'+benar+'</p><p class="text-xs text-muted">/ '+total+'</p></div>';
    h+='<div class="bg-card rounded-xl border border-border p-3"><p class="text-xs text-muted mb-1">Skor PG</p><p class="text-xl font-bold text-light">'+pgSkor+'</p><p class="text-xs text-muted">/ '+pgMax+' ('+pct+'%)</p></div>';
    h+='<div class="bg-card rounded-xl border border-border p-3"><p class="text-xs text-muted mb-1">Status</p><p class="text-xl font-bold '+(isLulus?'text-success':'text-danger')+'">'+(isLulus?'Tuntas':'Belum')+'</p><p class="text-xs text-muted">KKM 70</p></div>';
    h+='</div>';

    // Sent confirmation
    h+='<div class="p-3 bg-success/8 border border-success/25 rounded-xl text-xs text-success mb-5"><i class="fas fa-check-circle mr-1"></i>Nilai sudah terkirim ke guru</div>';

    // Pembahasan
    h+='<div class="text-left mb-4"><h4 class="text-sm font-bold text-light mb-3 flex items-center gap-2"><i class="fas fa-book-open text-kopAccent"></i>Pembahasan</h4><div class="space-y-2">';
    pgDetail.forEach(function(d){
        h+='<div class="p-3 rounded-xl '+(d.benar?'bg-success/5 border border-success/15':'bg-danger/5 border border-danger/15')+'">';
        h+='<div class="flex items-center gap-2 mb-1.5"><span class="text-xs font-bold '+(d.benar?'text-success':'text-danger')+'">'+(d.benar?'<i class="fas fa-check-circle"></i>':'<i class="fas fa-times-circle"></i>')+' Soal '+d.no+'</span></div>';
        h+='<p class="text-xs text-muted mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">'+escHtml(d.soal)+'</p>';
        h+='<div class="flex gap-4 text-xs"><span class="text-muted">Jawabmu: <strong class="inline-flex items-center justify-center w-5 h-5 rounded-full '+(d.benar?'bg-success/15 text-success':'bg-danger/15 text-danger')+'">'+(d.jawaban||'-')+'</strong></span><span class="text-muted">Kunci: <strong class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-success/15 text-success">'+escHtml(d.kunci)+'</strong></span></div></div>';
    });
    h+='</div></div>';

    // Tombol keluar
    h+='<button onclick="doLogout()" class="btn-secondary mb-8"><i class="fas fa-sign-out-alt mr-2"></i>Selesai & Keluar</button>';
    h+='</div>';

    document.getElementById('ujianResult').innerHTML=h;
    document.getElementById('ujianResult').classList.remove('hidden');
    window.scrollTo({top:0,behavior:'smooth'});
}

window.onload=initApp;
</script>
</body>
</html>
