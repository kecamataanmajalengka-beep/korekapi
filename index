function onTokenInput(){
    var inp=document.getElementById('lToken'),mask=document.getElementById('tokenMask'),err=document.getElementById('lTokenErr'),ok=document.getElementById('lTokenOk'),btn=document.getElementById('btnStep4');
    var val=(inp.value||'').trim().toUpperCase();inp.value=val;
