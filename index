    }

    // SAT untuk kelas 1-5
    var nonK6Gurus=matchedNpsnGurus.filter(function(g){return g.kelas!=='Kelas 6';});
    if(nonK6Gurus.length){
        nonK6Gurus.forEach(function(g){
            var satMapels=getSatMapelsForGuru(g);
            var doneCount=0;satMapels.forEach(function(m){if(alreadyDoneSet[m.id])doneCount++;});
            var allDone=doneCount===satMapels.length&&satMapels.length>0;
            h+='<div class="exam-type-card'+(allDone?' locked':'')+'" id="cardSAT_'+g.kelas.replace(' ','')+'" onclick="selectExamType(\'sat_'+g.kelas.replace(' ','')+'\')">' +
