    err.classList.add('hidden');ok.classList.add('hidden');btn.disabled=true;tokenValidated=false;
    if(val.length<8)return;
    var correct=(selectedGuru.tokenMapel||{})[selectedMapel]||'';
    if(val===correct){tokenValidated=true;ok.classList.remove('hidden');btn.disabled=false;inp.style.borderColor='#22c55e';inp.style.boxShadow='0 0 0 2px rgba(34,197,94,0.2)';document.getElementById('sd3').className='step-dot done';}
    else{err.textContent='Token salah!';err.classList.remove('hidden');inp.style.borderColor='#ef4444';inp.style.boxShadow='0 0 0 2px rgba(239,68,68,0.2)';document.getElementById('sd3').className='step-dot error';setTimeout(function(){document.getElementById('sd3').className='step-dot active';inp.style.borderColor='';inp.style.boxShadow='';},500);}
